pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
--mushroom party
--by real



local state=0
--0:title
--1:game
--2:gameover

local level=1


function _init()
	if state==1 then
		game_init()
	end
end


function _update60()
	if state==1 then
		game_update()
	elseif state==0 then
		title_update()
	elseif state==2 then
		gameover_update()
	end
end

function _draw()
	if state==1 then
		game_draw()
	elseif state==0 then
		title_draw()
	elseif state==2 then
		gameover_draw()
	end
end
-->8
--game


local mushrooms={}
local timer

local goal
--0 small, 1 big

local hero={
	x=15,
	y=15,
	dir=1
}


function game_init()

	goal = flr(rnd()*2)
	mushrooms={}

	timer=0
	--create mushrooms
	for i=1,level+1 do
		local mushroom={
			x=58,y=58,
			size=flr(rnd()*2),
			spx=rnd()*1.5 - 0.75,
			spy=rnd()*1.5 - 0.75,
		}
		add(mushrooms,mushroom)
	end
	--force 1 big and 1 small
	mushrooms[1].size=0
	mushrooms[2].size=1
	---------
	hero.x=15
	hero.y=15
end

function game_update()
	timer+=0.1
	for m in all (mushrooms) do
		m.x+=m.spx
		m.y+=m.spy
		if m.x<0 then
			m.x=0
			m.spx= -m.spx
		elseif m.x>120-m.size*8 then
			m.x=120-m.size*8
			m.spx= -m.spx
		end
		if m.y<0 then
			m.y=0
			m.spy= -m.spy
		elseif m.y>120-m.size*8 then
			m.y=120-m.size*8
			m.spy= -m.spy
		end
	end
	-------------player update
	if btn(⬅️) then
		hero.x-=1
		hero.dir=0
	end
	if btn(⬆️) then
		hero.y-=1
	end
	if btn(➡️) then
		hero.x+=1
		hero.dir=1
	end
	if btn(⬇️) then
		hero.y+=1
	end
	--bound
	if hero.x<0 then
		hero.x=0
	end
	if hero.x>120 then
		hero.x=120
	end
	if hero.y<0 then
		hero.y=0
	end
	if hero.y>120 then
		hero.y=120
	end
	--check collisions
	for m in all (mushrooms) do
		local s=m.size==0 and 8 or 16
		if hero.x+4>=m.x
		and hero.x+4<=m.x+s
		and hero.y+4>=m.y
		and hero.y+4<=m.y+s
		then
			if m.size==goal then
				sfx(0)
				del(mushrooms,m)
				iswin=true
				for m in all (mushrooms) do
					if m.size==goal then
						iswin=false
					end
				end
				if iswin then
					--win level
					level+=1
					game_init()
				end
			else
				state=2
			end
		end
	end
end

function game_draw()
	palt(0,false)
	palt(11,true)
	cls(3)
	
	for m in all (mushrooms) do
		if m.size==0 then
			spr(0,m.x,m.y)
		else
			spr(1,m.x,m.y,2,2)
		end
	end
	
	--hero
	spr(timer%3<1.5 and 3 or 4,
		hero.x,hero.y,1,1,
		hero.dir==0 and true or false)
	
	
	if timer<18 then
		if goal==0 then
			print ("pick all small mushrooms",20,20,7)
		else
			print ("pick all big mushrooms",20,20,7)
		end
	end
	
	rect(0,0,127,127,2)
	
end
-->8
--title

function title_update()
	if btnp(❎) then
		level=1
		state=1
		game_init()	
	end
end

function title_draw()
	cls(3)
	palt(11,true)
	spr(32,16,30,12,4)
	print("press ❎ to start",30,88,7)
end
-->8
--gameover

function gameover_update()
		if btnp(❎) then
		state=0
	end
end

function gameover_draw()
cls(3)
print("game over",46,45,10)
print("you reached level "..level,
25,55,7)
print("press ❎ to continue",22,78,7)
end
